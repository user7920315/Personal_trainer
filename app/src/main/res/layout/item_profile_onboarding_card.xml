<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_onboarding_card"
    android:padding="20dp"
    android:elevation="16dp">

    <!-- Шапка: счётчик + заголовок -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <!-- Заголовок шага -->
        <TextView
            android:id="@+id/tvOnbTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

        <!-- Счётчик "1 / 5" -->
        <TextView
            android:id="@+id/tvOnbCounter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#888888"
            android:background="#22FFFFFF"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp" />

    </LinearLayout>

    <!-- Разделитель -->
    <View
        android:layout_width="40dp"
        android:layout_height="2dp"
        android:background="#E94560"
        android:layout_marginBottom="12dp" />

    <!-- Текст подсказки -->
    <TextView
        android:id="@+id/tvOnbText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="#CCCCCC"
        android:lineSpacingMultiplier="1.5"
        android:layout_marginBottom="20dp" />

    <!-- Кнопки -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <!-- Пропустить -->
        <Button
            android:id="@+id/btnOnbSkip"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Пропустить"
            android:textSize="13sp"
            android:textColor="#888888"
            android:backgroundTint="#22FFFFFF"
            android:layout_marginEnd="8dp" />

        <!-- Далее / Готово -->
        <Button
            android:id="@+id/btnOnbNext"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Далее →"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#E94560" />

    </LinearLayout>

</LinearLayout>