<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_onboarding_card"
    android:elevation="16dp"
    android:orientation="vertical"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvOnbTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvOnbCounter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#22FFFFFF"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:textColor="#888888"
            android:textSize="12sp" />

    </LinearLayout>

    <View
        android:layout_width="40dp"
        android:layout_height="2dp"
        android:layout_marginBottom="12dp"
        android:background="#E94560" />

    <TextView
        android:id="@+id/tvOnbText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:lineSpacingMultiplier="1.5"
        android:textColor="#CCCCCC"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnOnbSkip"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#22FFFFFF"
            android:text="Пропустить"
            android:textColor="#888888"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btnOnbNext"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:backgroundTint="#E94560"
            android:text="Далее →"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />

    </LinearLayout>

</LinearLayout>