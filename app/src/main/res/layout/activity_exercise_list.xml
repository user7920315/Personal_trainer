<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A1A2E">

    <!-- Шапка -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/spacing_lg"
        android:paddingTop="@dimen/spacing_lg"
        android:paddingBottom="@dimen/spacing_md">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Привет! 👋"
                android:textSize="@dimen/text_sm"
                android:textColor="#AAAAAA"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Выбери упражнение"
                android:textSize="@dimen/list_header_text"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:maxLines="1"/>

        </LinearLayout>

        <!-- Кнопка профиля -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btnProfile"
            android:layout_width="@dimen/icon_sm"
            android:layout_height="@dimen/icon_sm"
            app:cardCornerRadius="24dp"
            app:cardBackgroundColor="#E94560"
            app:cardElevation="4dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="👤"
                android:textSize="@dimen/list_item_emoji"/>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- Поиск -->
    <EditText
        android:id="@+id/etSearch"
        android:layout_width="match_parent"
        android:layout_height="@dimen/search_height"
        android:layout_marginHorizontal="@dimen/spacing_lg"
        android:layout_marginBottom="@dimen/spacing_sm"
        android:hint="🔍 Поиск упражнений..."
        android:textColorHint="#666666"
        android:textColor="#FFFFFF"
        android:textSize="@dimen/text_md"
        android:background="@drawable/bg_search"
        android:paddingHorizontal="@dimen/spacing_md"
        android:inputType="text"
        android:imeOptions="actionSearch"
        android:maxLines="1"/>

    <!--
        layout_weight="1" + layout_height="0dp" — RecyclerView занимает
        всё оставшееся место, не выезжает за экран
    -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerExercises"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingVertical="@dimen/spacing_sm"
        android:clipToPadding="false"/>

</LinearLayout>