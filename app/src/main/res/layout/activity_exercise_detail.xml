<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── Видеоплеер ─────────────────────────────────────────── -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="230dp"
            android:background="#000000">

            <VideoView
                android:id="@+id/videoView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center" />

            <!-- Плейсхолдер если видео нет -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="🎬 Загрузка видео..."
                android:textColor="#555555"
                android:textSize="16sp" />

            <!-- Кнопка назад поверх видео -->
            <TextView
                android:id="@+id/btnDetailBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_margin="12dp"
                android:background="#88000000"
                android:padding="8dp"
                android:text="← Назад"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />

        </FrameLayout>

        <!-- ── Контент ────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Название упражнения -->
            <TextView
                android:id="@+id/tvDetailTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp" />

            <!-- Мышцы и сложность -->
            <TextView
                android:id="@+id/tvDetailMeta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#E94560"
                android:layout_marginBottom="20dp" />

            <!-- Разделитель -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#33FFFFFF"
                android:layout_marginBottom="20dp" />

            <!-- Заголовок описания -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📋 Техника выполнения"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#E94560"
                android:layout_marginBottom="12dp" />

            <!-- Текст описания -->
            <TextView
                android:id="@+id/tvDetailDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#DDDDDD"
                android:lineSpacingMultiplier="1.6"
                android:layout_marginBottom="32dp" />

            <!-- Кнопка начать тренировку -->
            <Button
                android:id="@+id/btnStartExercise"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="🚀 Начать тренировку"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#E94560"
                android:layout_marginBottom="16dp" />

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>