<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A1A2E">

    <!-- Шапка -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/spacing_md">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/btn_height_sm"
            android:text="← Назад"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/text_sm"
            android:backgroundTint="#33FFFFFF"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Профиль"
            android:textSize="@dimen/text_xl"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:maxLines="1"/>

        <!-- Заглушка для симметрии шапки -->
        <View
            android:layout_width="80dp"
            android:layout_height="@dimen/btn_height_sm"/>

    </LinearLayout>

    <!-- Основной скролл -->
    <ScrollView
        android:id="@+id/scrollViewProfile"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/spacing_xl">

            <!-- ── Блок аватара ───────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="@dimen/spacing_lg"
                android:paddingBottom="@dimen/spacing_md">

                <androidx.cardview.widget.CardView
                    android:layout_width="@dimen/profile_avatar"
                    android:layout_height="@dimen/profile_avatar"
                    app:cardCornerRadius="50dp"
                    app:cardBackgroundColor="#E94560">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="👤"
                        android:textSize="36sp"/>

                </androidx.cardview.widget.CardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Спортсмен"
                    android:textSize="@dimen/profile_title_text"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="@dimen/spacing_sm"/>

                <TextView
                    android:id="@+id/tvBmiCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Заполните данные ниже"
                    android:textSize="@dimen/text_sm"
                    android:textColor="#AAAAAA"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>

            <!-- ── Карточка ИМТ ───────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/card_margin"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardCornerRadius="@dimen/card_radius"
                app:cardBackgroundColor="#0F3460"
                app:cardElevation="@dimen/card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚖ Индекс массы тела"
                        android:textSize="@dimen/text_lg"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="@dimen/spacing_md"/>

                    <!-- Метка Пол -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Пол"
                        android:textSize="@dimen/text_xs"
                        android:textColor="#AAAAAA"
                        android:layout_marginBottom="@dimen/spacing_sm"/>

                    <!-- Кнопки выбора пола -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/btn_height_md"
                        android:orientation="horizontal"
                        android:layout_marginBottom="@dimen/spacing_md">

                        <LinearLayout
                            android:id="@+id/btnGenderMale"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:background="@drawable/bg_gender_selected"
                            android:layout_marginEnd="6dp"
                            android:clickable="true"
                            android:focusable="true">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="♂ "
                                android:textSize="@dimen/text_md"
                                android:textColor="#FFFFFF"/>

                            <TextView
                                android:id="@+id/tvGenderMaleLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Мужской"
                                android:textSize="@dimen/text_sm"
                                android:textColor="#FFFFFF"
                                android:textStyle="bold"
                                android:maxLines="1"/>

                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/btnGenderFemale"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:background="@drawable/bg_gender_unselected"
                            android:layout_marginStart="6dp"
                            android:clickable="true"
                            android:focusable="true">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="♀ "
                                android:textSize="@dimen/text_md"
                                android:textColor="#AAAAAA"/>

                            <TextView
                                android:id="@+id/tvGenderFemaleLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Женский"
                                android:textSize="@dimen/text_sm"
                                android:textColor="#AAAAAA"
                                android:maxLines="1"/>

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Рост и вес в одну строку -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="@dimen/spacing_sm">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Рост (см)"
                                android:textSize="@dimen/text_xs"
                                android:textColor="#AAAAAA"
                                android:layout_marginBottom="4dp"/>

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                                android:theme="@style/ThemeOverlay.Profile.Input">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etHeight"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="numberDecimal"
                                    android:hint="175"
                                    android:textColor="#FFFFFF"
                                    android:textSize="@dimen/text_md"
                                    android:textColorHint="#666666"/>

                            </com.google.android.material.textfield.TextInputLayout>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="@dimen/spacing_sm">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Вес (кг)"
                                android:textSize="@dimen/text_xs"
                                android:textColor="#AAAAAA"
                                android:layout_marginBottom="4dp"/>

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                                android:theme="@style/ThemeOverlay.Profile.Input">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etWeight"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="numberDecimal"
                                    android:hint="70"
                                    android:textColor="#FFFFFF"
                                    android:textSize="@dimen/text_md"
                                    android:textColorHint="#666666"/>

                            </com.google.android.material.textfield.TextInputLayout>

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Возраст -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Возраст"
                        android:textSize="@dimen/text_xs"
                        android:textColor="#AAAAAA"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:layout_marginBottom="4dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:theme="@style/ThemeOverlay.Profile.Input">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etAge"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:hint="25"
                            android:textColor="#FFFFFF"
                            android:textSize="@dimen/text_md"
                            android:textColorHint="#666666"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Кнопка расчёта -->
                    <Button
                        android:id="@+id/btnCalculateBmi"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/btn_height_md"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:text="Рассчитать ИМТ"
                        android:textColor="#FFFFFF"
                        android:textSize="@dimen/text_md"
                        android:backgroundTint="#E94560"/>

                    <!-- Результат ИМТ -->
                    <LinearLayout
                        android:id="@+id/layoutBmiResult"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:padding="@dimen/spacing_sm"
                        android:background="@drawable/bg_bmi_result"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="ИМТ"
                                    android:textSize="@dimen/text_xs"
                                    android:textColor="#AAAAAA"/>

                                <TextView
                                    android:id="@+id/tvBmiValue"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="—"
                                    android:textSize="@dimen/bmi_value_text"
                                    android:textStyle="bold"
                                    android:textColor="#FFFFFF"/>

                            </LinearLayout>

                            <View
                                android:layout_width="1dp"
                                android:layout_height="44dp"
                                android:background="#33FFFFFF"/>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Категория"
                                    android:textSize="@dimen/text_xs"
                                    android:textColor="#AAAAAA"/>

                                <TextView
                                    android:id="@+id/tvBmiResultCategory"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="—"
                                    android:textSize="@dimen/bmi_category_text"
                                    android:textStyle="bold"
                                    android:textColor="#00FF88"
                                    android:gravity="center"
                                    android:maxLines="2"/>

                            </LinearLayout>

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvBmiNorm"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="@dimen/text_xs"
                            android:textColor="#AAAAAA"
                            android:gravity="center"
                            android:layout_marginTop="@dimen/spacing_sm"
                            android:maxLines="2"/>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ── Карточка динамики веса ─────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/card_margin"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardCornerRadius="@dimen/card_radius"
                app:cardBackgroundColor="#0F3460"
                app:cardElevation="@dimen/card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📈 Динамика веса"
                        android:textSize="@dimen/text_lg"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="@dimen/spacing_sm"/>

                    <TextView
                        android:id="@+id/tvNoWeightData"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Сохраните вес несколько раз&#10;чтобы увидеть динамику"
                        android:textColor="#666666"
                        android:textSize="@dimen/text_sm"
                        android:gravity="center"
                        android:padding="@dimen/spacing_lg"
                        android:visibility="visible"/>

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/weightChart"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/chart_height"
                        android:visibility="gone"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ── Карточка статистики ────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/card_margin"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardCornerRadius="@dimen/card_radius"
                app:cardBackgroundColor="#0F3460"
                app:cardElevation="@dimen/card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏆 Статистика"
                        android:textSize="@dimen/text_lg"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="@dimen/spacing_md"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:baselineAligned="false">

                        <!-- Всего тренировок -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/bg_stat_card"
                            android:padding="@dimen/stat_card_padding"
                            android:layout_marginEnd="4dp"
                            android:minHeight="@dimen/stat_min_height">

                            <TextView
                                android:id="@+id/tvTotalWorkouts"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="@dimen/stat_value_text"
                                android:textStyle="bold"
                                android:textColor="#E94560"
                                android:maxLines="1"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Тренировок"
                                android:textSize="@dimen/stat_label_text"
                                android:textColor="#AAAAAA"
                                android:gravity="center"
                                android:maxLines="1"/>

                        </LinearLayout>

                        <!-- Дней подряд -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/bg_stat_card"
                            android:padding="@dimen/stat_card_padding"
                            android:layout_marginHorizontal="4dp"
                            android:minHeight="@dimen/stat_min_height">

                            <TextView
                                android:id="@+id/tvCurrentStreak"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="@dimen/stat_value_text"
                                android:textStyle="bold"
                                android:textColor="#FFD700"
                                android:maxLines="1"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Дней подряд"
                                android:textSize="@dimen/stat_label_text"
                                android:textColor="#AAAAAA"
                                android:gravity="center"
                                android:maxLines="1"/>

                        </LinearLayout>

                        <!-- На этой неделе -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/bg_stat_card"
                            android:padding="@dimen/stat_card_padding"
                            android:layout_marginStart="4dp"
                            android:minHeight="@dimen/stat_min_height">

                            <TextView
                                android:id="@+id/tvWeekWorkouts"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="@dimen/stat_value_text"
                                android:textStyle="bold"
                                android:textColor="#00AAFF"
                                android:maxLines="1"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="На неделе"
                                android:textSize="@dimen/stat_label_text"
                                android:textColor="#AAAAAA"
                                android:gravity="center"
                                android:maxLines="1"/>

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ── Карточка истории тренировок ───────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/card_margin"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardCornerRadius="@dimen/card_radius"
                app:cardBackgroundColor="#0F3460"
                app:cardElevation="@dimen/card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <!-- Заголовок + кнопка очистки -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/spacing_sm">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="📋 История тренировок"
                            android:textSize="@dimen/text_lg"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:maxLines="1"
                            android:ellipsize="end"/>

                        <Button
                            android:id="@+id/btnClearHistory"
                            android:layout_width="wrap_content"
                            android:layout_height="@dimen/btn_height_sm"
                            android:text="Очистить"
                            android:textSize="@dimen/text_xs"
                            android:textColor="#AAAAAA"
                            android:backgroundTint="#22FFFFFF"
                            android:paddingHorizontal="@dimen/spacing_sm"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvNoHistory"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="История тренировок пуста&#10;Начните тренироваться!"
                        android:textColor="#666666"
                        android:textSize="@dimen/text_sm"
                        android:gravity="center"
                        android:padding="@dimen/spacing_lg"
                        android:visibility="visible"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvHistory"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:visibility="gone"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

</LinearLayout>