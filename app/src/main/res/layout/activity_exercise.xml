<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:implementationMode="compatible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ru.sv.personaltrainer.overlay.PoseOverlayView
        android:id="@+id/poseOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvRepCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/exercise_side_margin"
        android:layout_marginTop="@dimen/exercise_top_margin"
        android:background="@color/video_bg_black"
        android:maxLines="1"
        android:padding="@dimen/spacing_sm"
        android:text="@string/rep_count_zero"
        android:textColor="@color/white"
        android:textSize="@dimen/rep_count_text"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="@dimen/exercise_side_margin"
        android:layout_marginTop="@dimen/spacing_xs"
        android:padding="12dp"
        android:src="@drawable/arrow_back"
        android:background="@drawable/bg_square_outline"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvRepCount" />

    <TextView
        android:id="@+id/tvExerciseName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/exercise_top_margin"
        android:layout_marginEnd="@dimen/exercise_side_margin"
        android:background="@color/card_exercise_name_bg"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:padding="@dimen/spacing_sm"
        android:text="@string/exercise_default_title"
        android:textColor="@color/white"
        android:textSize="@dimen/exercise_name_text"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_max="160dp" />

    <TextView
        android:id="@+id/tvPhase"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@color/video_phase_bg"
        android:padding="@dimen/spacing_sm"
        android:text="@string/phase_ready"
        android:textColor="@color/accent"
        android:textSize="@dimen/phase_text_size"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/tvRepCount"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/layoutRecordingIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/exercise_side_margin"
        android:layout_marginTop="@dimen/spacing_xs"
        android:background="@color/video_bg_black"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_sm"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnBack">

        <View
            android:id="@+id/viewRecordingDot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_recording_dot" />

        <TextView
            android:id="@+id/tvRecordingTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/timer_zero"
            android:textColor="@color/white"
            android:textSize="@dimen/text_sm"
            android:textStyle="bold" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutButtons"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/feedback_card_margin"
        android:layout_marginBottom="@dimen/spacing_sm"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toTopOf="@id/cardFeedback"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/btnToggleTts"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:padding="12dp"
            android:src="@drawable/volume_up"
            android:background="@drawable/bg_square_outline"
            android:clickable="true"
            android:focusable="true"/>

        <ImageView
            android:id="@+id/btnRecord"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:padding="12dp"
            android:src="@drawable/record"
            android:background="@drawable/bg_square_outline"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/btn_record" />

        <ImageView
            android:id="@+id/btnReset"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="12dp"
            android:src="@drawable/record"
            android:background="@drawable/bg_square_outline"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/btn_reset" />

    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/cardFeedback"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/feedback_card_margin"
        android:layout_marginEnd="@dimen/feedback_card_margin"
        android:layout_marginBottom="@dimen/feedback_card_margin"
        app:cardBackgroundColor="@color/video_feedback_bg"
        app:cardCornerRadius="@dimen/card_radius"
        app:cardElevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/feedback_card_padding">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:maxLines="1"
                    android:text="@string/analysis_title"
                    android:textColor="@color/primary"
                    android:textSize="@dimen/feedback_title_text"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvQuality"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/quality_full"
                    android:textColor="@color/accent"
                    android:textSize="@dimen/feedback_title_text" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:background="@color/divider_light" />

            <TextView
                android:id="@+id/tvFeedback"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_xs"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="@string/feedback_start_analysis"
                android:textColor="@color/white"
                android:textSize="@dimen/feedback_body_text"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/layoutErrors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginBottom="@dimen/spacing_xs"
                    android:background="@color/error_divider" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="2dp"
                    android:text="@string/also_fix"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_xs" />

                <TextView
                    android:id="@+id/tvErrors"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:lineSpacingExtra="3dp"
                    android:maxLines="3"
                    android:textColor="@color/error_light"
                    android:textSize="@dimen/feedback_error_text" />

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>